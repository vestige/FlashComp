rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return isSignedIn() && exists(userDocPath());
    }

    function userProfile() {
      return get(userDocPath()).data;
    }

    function isOwner() {
      return hasUserProfile()
        && (userProfile().role == "owner" || userProfile().role == "admin");
    }

    function isViewer() {
      return hasUserProfile() && (
        userProfile().role == "viewer"
        || userProfile().role == "owner"
        || userProfile().role == "admin"
      );
    }

    function isAdmin() {
      return hasUserProfile() && userProfile().role == "admin";
    }

    function ownerGymIds() {
      return isOwner() ? userProfile().gymIds : [];
    }

    function hasAllGymAccess() {
      return isOwner() && (isAdmin() || "*" in ownerGymIds());
    }

    function hasGymAccess(gymId) {
      return isOwner()
        && gymId is string
        && (hasAllGymAccess() || gymId in ownerGymIds());
    }

    function canReadPublic() {
      return true;
    }

    function canReadManagementData() {
      return isViewer();
    }

    function canReadManagementEvent(eventId) {
      return isOwner()
        && exists(eventDocPath(eventId))
        && (hasAllGymAccess() || get(eventDocPath(eventId)).data.gymId in ownerGymIds());
    }

    function canWriteManagementEvent(eventId) {
      return canManageEvent(eventId);
    }

    function eventDocPath(eventId) {
      return /databases/$(database)/documents/events/$(eventId);
    }

    function canManageEvent(eventId) {
      return isOwner()
        && exists(eventDocPath(eventId))
        && (hasAllGymAccess() || get(eventDocPath(eventId)).data.gymId in ownerGymIds());
    }

    // Public event browsing for climbers + management read/write split.
    match /events/{eventId} {
      allow read: if canReadPublic() || canReadManagementData() || canReadManagementEvent(eventId);
      allow create: if hasGymAccess(request.resource.data.gymId);
      allow update: if canWriteManagementEvent(eventId)
        && request.resource.data.gymId == resource.data.gymId;
      allow delete: if canWriteManagementEvent(eventId);
    }

    // Event subcollections (seasons/categories/routes/participants/scores).
    match /events/{eventId}/{document=**} {
      allow read: if canReadPublic() || canReadManagementData() || canReadManagementEvent(eventId);
      allow write: if canWriteManagementEvent(eventId);
    }

    // Public gym metadata for event browsing filters.
    match /gyms/{gymId} {
      allow read: if canReadPublic() || canReadManagementData();
      allow write: if isAdmin();
    }

    // Owner/admin profile.
    // Note: To satisfy event write checks, users/{uid} should include role/gymIds.
    match /users/{userId} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && (
          isAdmin() || (
            request.auth.uid == userId
            && request.resource.data.role == "viewer"
            && request.resource.data.gymIds is list
            && request.resource.data.gymIds.size() == 0
          )
        );
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
