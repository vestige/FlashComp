{
  "name": "flash-comp-app",
  "private": true,
  "homepage": "https://vestige.github.io/FlashComp",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode prod",
    "build:demo": "vite build --mode demo",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "db:purge": "node scripts/purgeFirestoreData.js",
    "db:purge:yes": "node scripts/purgeFirestoreData.js --yes",
    "db:purge:yes:system": "node scripts/purgeFirestoreData.js --yes --include-system",
    "db:clear": "node scripts/purgeFirestoreData.js --yes --all",
    "db:format:demo": "node scripts/purgeFirestoreData.js --yes --include-system && node scripts/seedFirestoreData.js --include-system",
    "db:seed": "node scripts/seedFirestoreData.js",
    "db:seed:system": "node scripts/seedFirestoreData.js --include-system",
    "db:backup": "node scripts/backupFirestoreData.js",
    "db:backup:demo": "node scripts/backupFirestoreData.js --env demo",
    "db:backup:prod": "node scripts/backupFirestoreData.js --env prod",
    "db:backup:system": "node scripts/backupFirestoreData.js --include-system",
    "db:restore": "node scripts/restoreFirestoreData.js",
    "db:restore:prod": "node scripts/restoreFirestoreData.js --env prod",
    "db:restore:demo": "node scripts/restoreFirestoreData.js --env demo",
    "db:restore:dry-run": "node scripts/restoreFirestoreData.js --dry-run",
    "db:reset": "node scripts/purgeFirestoreData.js --yes && node scripts/seedFirestoreData.js",
    "verify:owner-access": "node scripts/verifyOwnerAccess.js"
  },
  "dependencies": {
    "firebase": "^11.9.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "gh-pages": "^6.3.0",
    "globals": "^16.0.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "vite": "^6.3.5",
    "vitest": "^4.0.18"
  }
}
